[include]
  path = ~/.gitcredentials

[init]
	defaultBranch = main

[core]
	excludesfile = ~/.gitignore

[color]
	ui = auto

[grep]
	lineNumber = true

[pull]
	default = simple
	ff = only
	rebase = false

[push]
	default = simple

[branch]
	autosetupmerge = true
	autosetuprebase = always

[merge]
	conflictstyle = diff3
